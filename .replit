modules = ["java-graalvm22.3", "nodejs-20", "web", "bash", "python-3.11"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["netcat-gnu"]

[[ports]]
localPort = 5000
externalPort = 5000


[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BUILD_URL=http://localhost:5000 node /home/runner/workspace/server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
