modules = ["java-graalvm22.3", "nodejs-20", "web", "bash", "python-3.11"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["netcat-gnu"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6009
externalPort = 3001

[[ports]]
localPort = 7000
externalPort = 80

[[ports]]
localPort = 7500
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"
