modules = ["java-graalvm22.3", "nodejs-20", "web", "bash", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["netcat-gnu"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 6000
externalPort = 6000

[[ports]]
localPort = 6009
externalPort = 3001

[[ports]]
localPort = 7000
externalPort = 3000

[[ports]]
localPort = 7500
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Device Simulator"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "APK Build"

[[workflows.workflow]]
name = "Backend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm install --prefer-offline && npm run build && node server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "APK Build"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash build.sh"
