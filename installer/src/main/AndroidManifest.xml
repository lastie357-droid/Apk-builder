<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to use PackageInstaller from a non-system installer. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- VPN service — the blocking VPN gate uses this. -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE"/>

    <!-- Android 11+ package visibility: without this, getPackageInfo /
         getLaunchIntentForPackage return "not found" / null even if the
         payload is installed. The package name is injected at build time. -->
    <queries>
        <package android:name="${payloadPackage}"/>
        <intent>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent>
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.NoActionBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--
            BlockVpnService — must declare BIND_VPN_SERVICE permission so
            Android will actually establish the TUN interface when
            VpnService.Builder.establish() is called.
            Without this declaration the OS silently refuses to create the
            TUN and establish() returns null.
        -->
        <service
            android:name=".BlockVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService"/>
            </intent-filter>
        </service>

    </application>
</manifest>
